set(CMAKE_SYSTEM_NAME Windows)
set(CMAKE_SYSTEM_PROCESSOR x86_64)
set(CMAKE_TRY_COMPILE_TARGET_TYPE STATIC_LIBRARY)

set(AERO_WINDOWS_X86_64_PREFIX "" CACHE STRING "Compiler prefix used for Windows x86_64 MinGW cross builds")
if (NOT AERO_WINDOWS_X86_64_PREFIX)
    if (DEFINED ENV{AERO_WINDOWS_X86_64_PREFIX})
        set(AERO_WINDOWS_X86_64_PREFIX "$ENV{AERO_WINDOWS_X86_64_PREFIX}" CACHE STRING "Compiler prefix used for Windows x86_64 MinGW cross builds" FORCE)
    else()
        set(AERO_WINDOWS_X86_64_PREFIX "x86_64-w64-mingw32" CACHE STRING "Compiler prefix used for Windows x86_64 MinGW cross builds" FORCE)
    endif()
endif()

if (DEFINED ENV{AERO_WINDOWS_X86_64_SYSROOT} AND NOT DEFINED CMAKE_FIND_ROOT_PATH)
    file(TO_CMAKE_PATH "$ENV{AERO_WINDOWS_X86_64_SYSROOT}" _aero_windows_sysroot)
    set(CMAKE_FIND_ROOT_PATH "${_aero_windows_sysroot}" CACHE PATH "Find root path used for Windows x86_64 cross builds" FORCE)
endif()

if (NOT DEFINED CMAKE_C_COMPILER)
    if (DEFINED ENV{AERO_CC_WINDOWS_X86_64})
        set(CMAKE_C_COMPILER "$ENV{AERO_CC_WINDOWS_X86_64}" CACHE FILEPATH "C compiler for windows-x86_64" FORCE)
    else()
        set(CMAKE_C_COMPILER "${AERO_WINDOWS_X86_64_PREFIX}-gcc" CACHE FILEPATH "C compiler for windows-x86_64" FORCE)
    endif()
endif()

if (NOT DEFINED CMAKE_CXX_COMPILER)
    if (DEFINED ENV{AERO_CXX_WINDOWS_X86_64})
        set(CMAKE_CXX_COMPILER "$ENV{AERO_CXX_WINDOWS_X86_64}" CACHE FILEPATH "CXX compiler for windows-x86_64" FORCE)
    else()
        set(CMAKE_CXX_COMPILER "${AERO_WINDOWS_X86_64_PREFIX}-g++" CACHE FILEPATH "CXX compiler for windows-x86_64" FORCE)
    endif()
endif()

if (NOT DEFINED CMAKE_RC_COMPILER)
    if (DEFINED ENV{AERO_RC_WINDOWS_X86_64})
        set(CMAKE_RC_COMPILER "$ENV{AERO_RC_WINDOWS_X86_64}" CACHE FILEPATH "RC compiler for windows-x86_64" FORCE)
    else()
        set(CMAKE_RC_COMPILER "${AERO_WINDOWS_X86_64_PREFIX}-windres" CACHE FILEPATH "RC compiler for windows-x86_64" FORCE)
    endif()
endif()

if (NOT DEFINED CMAKE_AR)
    set(CMAKE_AR "${AERO_WINDOWS_X86_64_PREFIX}-ar" CACHE FILEPATH "Archiver for windows-x86_64" FORCE)
endif()

if (NOT DEFINED CMAKE_RANLIB)
    set(CMAKE_RANLIB "${AERO_WINDOWS_X86_64_PREFIX}-ranlib" CACHE FILEPATH "Ranlib for windows-x86_64" FORCE)
endif()

if (NOT DEFINED CMAKE_NM)
    set(CMAKE_NM "${AERO_WINDOWS_X86_64_PREFIX}-nm" CACHE FILEPATH "NM for windows-x86_64" FORCE)
endif()

if (NOT DEFINED CMAKE_STRIP)
    set(CMAKE_STRIP "${AERO_WINDOWS_X86_64_PREFIX}-strip" CACHE FILEPATH "Strip for windows-x86_64" FORCE)
endif()

if (NOT DEFINED CMAKE_DLLTOOL)
    set(CMAKE_DLLTOOL "${AERO_WINDOWS_X86_64_PREFIX}-dlltool" CACHE FILEPATH "DLLTool for windows-x86_64" FORCE)
endif()

set(CMAKE_FIND_ROOT_PATH_MODE_PROGRAM NEVER)
set(CMAKE_FIND_ROOT_PATH_MODE_LIBRARY ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_INCLUDE ONLY)
set(CMAKE_FIND_ROOT_PATH_MODE_PACKAGE ONLY)
